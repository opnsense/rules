alert http $HOME_NET any -> $EXTERNAL_NET $HTTP_PORTS (msg:"OPN_Mail - Libero_Mail - Related URL (mail.libero.it)"; http.uri; content:"mail.libero.it"; flow:to_server,established; reference:url,mail; classtype:policy-violation; sid:54000187; rev:1;)
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"OPN_Mail - Libero_Mail - Related TLS SNI (mail.libero.it)"; tls.sni; content:"mail.libero.it"; flow:to_server,established; reference:url,mail; classtype:policy-violation; sid:54000188; rev:1;)

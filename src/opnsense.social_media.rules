alert dns $HOME_NET any -> any 53 (msg:"OPN_Social_Media - Tumblr - DNS request for tumblr.com"; dns.query; content:"tumblr.com"; nocase; reference:url,social-media; classtype:policy-violation; sid:51000093; rev:1;)
alert http $HOME_NET any -> $EXTERNAL_NET $HTTP_PORTS (msg:"OPN_Social_Media - Tumblr - Related URL (tumblr.com)"; http.uri; content:"tumblr.com"; flow:to_server,established; reference:url,social-media; classtype:policy-violation; sid:51000094; rev:1;)
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"OPN_Social_Media - Tumblr - Related TLS SNI (tumblr.com)"; tls.sni; content:"tumblr.com"; flow:to_server,established; reference:url,social-media; classtype:policy-violation; sid:51000095; rev:1;)

alert dns $HOME_NET any -> any 53 (msg:"OPN_Media_Streaming - Channel4 - DNS request for channel4.com"; dns.query; content:"channel4.com"; nocase; reference:url,media-streaming; classtype:policy-violation; sid:55000177; rev:1;)
